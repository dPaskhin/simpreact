{
  "name": "@simpreact/simpreact",
  "version": "0.0.12",
  "description": "",
  "homepage": "https://github.com/dPaskhin/simpreact#readme",
  "main": "./core/index.js",
  "module": "./core/index.js",
  "types": "./core/index.d.ts",
  "exports": {
    ".": {
      "import": "./core/index.js",
      "types": "./core/index.d.ts"
    },
    "./compat": {
      "import": "./compat/index.js",
      "types": "./compat/index.d.ts",
      "default": "./compat/index.js"
    },
    "./compat/jsx-runtime": {
      "import": "./compat/jsx-runtime.js",
      "types": "./jsx-runtime/index.d.ts",
      "default": "./compat/jsx-runtime.js"
    },
    "./compat/jsx-dev-runtime": {
      "import": "./compat/jsx-runtime.js",
      "types": "./jsx-runtime/index.d.ts",
      "default": "./compat/jsx-runtime.js"
    },
    "./compat/*": {
      "import": "./compat/index.js",
      "default": "./compat/index.js"
    },
    "./component": {
      "import": "./component/index.js",
      "types": "./component/index.d.ts"
    },
    "./context/*": {
      "import": "./context/index.js",
      "types": "./context/index.d.ts"
    },
    "./internal": {
      "import": "./core/internal.js",
      "types": "./core/internal.d.ts"
    },
    "./jsx-runtime": {
      "import": "./jsx-runtime/index.js",
      "types": "./jsx-runtime/index.d.ts",
      "default": "./jsx-runtime/index.js"
    },
    "./jsx-dev-runtime": {
      "import": "./jsx-runtime/index.js",
      "types": "./jsx-runtime/index.d.ts",
      "default": "./jsx-runtime/index.js"
    },
    "./hooks": {
      "import": "./hooks/index.js",
      "types": "./hooks/index.d.ts"
    },
    "./dom": {
      "import": "./dom/index.js",
      "types": "./dom/index.d.ts"
    },
    "./shared": {
      "import": "./shared/index.js",
      "types": "./shared/index.d.ts"
    },
    "./signals": {
      "import": "./signals/index.js",
      "types": "./signals/index.d.ts"
    }
  },
  "bugs": {
    "url": "https://github.com/dPaskhin/simpreact/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dPaskhin/simpreact.git"
  },
  "sideEffects": false,
  "type": "module",
  "license": "MIT",
  "author": "Dmitrii Paskhin <d.pasxin@gmail.com>",
  "scripts": {
    "build": "npm run clean && tsc --project tsconfig.build.json && node move-types.mjs && tsc-alias && cp package.json README.md LICENSE.txt lib/ && cd lib && npm pkg delete scripts devDependencies",
    "test": "vitest --coverage",
    "format": "biome check --write --unsafe",
    "typecheck": "tsc --project tsconfig.typecheck.json",
    "clean": "rimraf lib",
    "bench": "bash scripts/bench.sh",
    "bench:save": "bash scripts/bench.sh --outputJson bench-baseline.json",
    "bench:compare": "bash scripts/bench.sh --compare bench-baseline.json",
    "mem": "NODE_ENV=production node --expose-gc scripts/mem.mjs",
    "mem:save": "NODE_ENV=production node --expose-gc scripts/mem.mjs --save mem-baseline.json",
    "mem:compare": "NODE_ENV=production node --expose-gc scripts/mem.mjs --compare mem-baseline.json"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.3",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitest/coverage-v8": "^3.1.3",
    "flyweight-dom": "^2.1.0",
    "inferno": "^9.0.3",
    "inferno-create-element": "^9.0.3",
    "inferno-hyperscript": "^9.0.3",
    "jsdom": "^26.1.0",
    "preact": "^10.27.0",
    "prettier": "^3.5.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "rimraf": "^6.0.1",
    "toofast": "^3.0.3",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.3"
  },
  "dependencies": {
    "csstype": "^3.1.3"
  }
}
